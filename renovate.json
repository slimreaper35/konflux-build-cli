{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "postUpdateOptions": ["gomodTidy"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["integration_tests/**/*.go"],
      "matchStrings": ["\"quay\\.io/konflux-ci/task-runner:(?<currentValue>[^@\"]+)(@(?<currentDigest>sha256:[a-f0-9]+))?\""],
      "depNameTemplate": "quay.io/konflux-ci/task-runner",
      "datasourceTemplate": "docker",
      "autoReplaceStringTemplate": "\"quay.io/konflux-ci/task-runner:{{{newValue}}}{{#if newDigest}}@{{{newDigest}}}{{/if}}\""
    }
  ],
  "packageRules": [
    {
      "description": "Disable Go indirect dependency updates",
      "matchManagers": ["gomod"],
      "matchDepTypes": ["indirect"],
      "enabled": false
    },
    {
      "description": "Group task-runner updates",
      "matchPackageNames": ["quay.io/konflux-ci/task-runner"],
      "groupName": "task-runner"
    },
    {
      "description": "Go minor updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor"],
      "groupName": "go minor dependencies"
    },
    {
      "description": "Go patch updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch"],
      "groupName": "go patch dependencies"
    },
    {
      "description": "Go digest updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["digest"],
      "groupName": "go digest dependencies"
    }
  ]
}
